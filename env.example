# ===================================
# 环境变量配置示例
# ===================================
# 
# 使用说明：
# 1. 复制本文件为 .env
# 2. 填写实际的配置值
# 3. .env 文件不会被提交到 Git（已在 .gitignore 中配置）
#

# ===================================
# 数据库配置
# ===================================
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/breast_health

# ===================================
# Flask 配置
# ===================================
FLASK_ENV=development
SECRET_KEY=your-secret-key-here-change-in-production

# ===================================
# OpenRouter API 配置
# ===================================
OPENROUTER_API_KEY=sk-or-v1-your-api-key-here
OPENROUTER_MODEL=google/gemini-2.5-pro

# ===================================
# 小程序 / 第三方平台配置
# ===================================
# 小程序插件：AI舌诊 idCode（用于小程序 plugin.init；没有可留空）
AI_TONGUE_ID_CODE=

# AI舌诊开放平台（企业应用）鉴权信息（强烈建议只放服务端，不要放到小程序）
AI_TONGUE_BASE_URL=https://www.ai-tongue.com
AI_TONGUE_DEVID=your_devid
AI_TONGUE_DEVSECRET=your_devsecret

# 可选：如果你希望限制“公司小程序 -> 你们后端”的调用来源，可以设置一个共享密钥
# 小程序请求时带 header: X-Miniprogram-Token: <MINIPROGRAM_API_TOKEN>
MINIPROGRAM_API_TOKEN=

# ===================================
# 其他配置
# ===================================
# 是否开启调试模式
DEBUG=True

# 日志级别
LOG_LEVEL=INFO

